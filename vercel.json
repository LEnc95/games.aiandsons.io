{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "devCommand": null,
  "installCommand": null,
  "framework": null,
  "rewrites": [
    {
      "source": "/pong",
      "destination": "/pong/index.html"
    },
    {
      "source": "/pong/",
      "destination": "/pong/index.html"
    },
    {
      "source": "/pingpong",
      "destination": "/pong/index.html"
    },
    {
      "source": "/pingpong/",
      "destination": "/pong/index.html"
    },
    {
      "source": "/snake",
      "destination": "/snake/index.html"
    },
    {
      "source": "/snake/",
      "destination": "/snake/index.html"
    },
    {
      "source": "/tictactoe",
      "destination": "/tictactoe/index.html"
    },
    {
      "source": "/tictactoe/",
      "destination": "/tictactoe/index.html"
    },
    {
      "source": "/rps",
      "destination": "/rps/index.html"
    },
    {
      "source": "/rps/",
      "destination": "/rps/index.html"
    },
    {
      "source": "/memory",
      "destination": "/memory/index.html"
    },
    {
      "source": "/memory/",
      "destination": "/memory/index.html"
    },
    {
      "source": "/breakout",
      "destination": "/breakout/index.html"
    },
    {
      "source": "/breakout/",
      "destination": "/breakout/index.html"
    },
    {
      "source": "/ski",
      "destination": "/ski/index.html"
    },
    {
      "source": "/ski/",
      "destination": "/ski/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    },
    {
      "source": "/pong/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/snake/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/tictactoe/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/rps/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/memory/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/breakout/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}

