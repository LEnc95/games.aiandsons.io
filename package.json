{
  "name": "cade-games-arcade",
  "private": true,
  "version": "0.0.0",
  "description": "Static browser arcade site",
  "scripts": {
    "test:shop": "node --test tests/shop-items.integration.test.mjs tests/entitlements.integration.test.mjs tests/premium-challenges.integration.test.mjs tests/metrics.integration.test.mjs tests/billing.integration.test.mjs tests/stripe-store.integration.test.mjs tests/kpi-export.integration.test.mjs tests/stripe-admin-auth.integration.test.mjs tests/stripe-reconcile-audit.integration.test.mjs",
    "feedback:check-daily": "node scripts/feedback/check-daily-workflow.mjs",
    "test:feedback": "npm run feedback:check-daily && node --test tests/feedback-admin-auth.integration.test.mjs tests/feedback-coverage.integration.test.mjs tests/feedback-api.integration.test.mjs tests/slack-ci.integration.test.mjs",
    "feedback:sync-linear": "node scripts/feedback/sync-linear-seeds.mjs",
    "feedback:sync-linear:files": "node scripts/feedback/sync-linear-seeds.mjs --skip-live",
    "feedback:provision-linear": "node scripts/feedback/provision-linear.mjs",
    "metrics:export": "node scripts/metrics/export-kpi-snapshot.mjs",
    "stripe:reconcile-audit": "node scripts/stripe/reconcile-audit.mjs",
    "test:classroom-smoke": "node scripts/qa/run-classroom-smoke.mjs",
    "test:classroom-smoke:raw": "node scripts/qa/classroom-mode-smoke.mjs http://127.0.0.1:4173",
    "test:feedback-smoke:raw": "node scripts/qa/feedback-smoke.mjs http://127.0.0.1:4173",
    "test:discovery-smoke:raw": "node scripts/qa/discovery-search-filter-smoke.mjs http://127.0.0.1:4173",
    "test:missions-smoke:raw": "node scripts/qa/daily-missions-smoke.mjs http://127.0.0.1:4173",
    "test:weekly-smoke:raw": "node scripts/qa/weekly-challenges-smoke.mjs http://127.0.0.1:4173",
    "test:assignment-smoke:raw": "node scripts/qa/assignment-bundle-smoke.mjs http://127.0.0.1:4173",
    "test:entitlements-smoke:raw": "node scripts/qa/entitlements-shop-smoke.mjs http://127.0.0.1:4173",
    "test:pricing-smoke:raw": "node scripts/qa/pricing-checkout-smoke.mjs http://127.0.0.1:4173",
    "test:premium-track-smoke:raw": "node scripts/qa/premium-track-smoke.mjs http://127.0.0.1:4173",
    "test:school-license-smoke:raw": "node scripts/qa/school-license-smoke.mjs http://127.0.0.1:4173",
    "test:report-smoke:raw": "node scripts/qa/report-generator-smoke.mjs http://127.0.0.1:4173",
    "test:policy-gate": "node scripts/release/policy-gate.mjs --require-approval",
    "test:accessibility-smoke:raw": "node scripts/qa/accessibility-pack-smoke.mjs http://127.0.0.1:4173",
    "test:onboarding-smoke:raw": "node scripts/qa/onboarding-split-smoke.mjs http://127.0.0.1:4173",
    "test:metrics-smoke:raw": "node scripts/qa/metrics-baseline-smoke.mjs http://127.0.0.1:4173",
    "test:launch-readiness-smoke": "node scripts/qa/run-launch-readiness-smoke.mjs",
    "test:launch-readiness-smoke:raw": "node scripts/qa/launch-readiness-smoke.mjs http://127.0.0.1:4173",
    "test:qa": "npm run test:shop && npm run test:feedback && npm run test:classroom-smoke"
  },
  "dependencies": {
    "stripe": "^20.4.0"
  },
  "devDependencies": {
    "playwright": "^1.50.0"
  }
}
